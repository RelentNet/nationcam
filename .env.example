# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Logto Auth ───────────────────────────────────────────────
# Public URL of your Logto instance (managed separately in Coolify)
LOGTO_ENDPOINT=https://auth.nationcam.com
# App ID created in Logto admin console (leave empty until first deploy)
LOGTO_APP_ID=
# API resource identifier registered in Logto
LOGTO_API_RESOURCE=https://api.nationcam.com

# ── Restreamer (optional) ─────────────────────────────────────
# Self-hosted datarhei Restreamer instance for RTSP-to-HLS conversion.
# Leave RESTREAMER_URL empty to disable stream management endpoints.
RESTREAMER_URL=https://streamer.nationcam.com
RESTREAMER_USER=admin
RESTREAMER_PASS=changeme
# API key required for all /api/streams/* requests
STREAMER_API_KEY=your-secret-api-key

# ── SSR web-next ─────────────────────────────────────────────
# Internal address the SSR server uses to reach the Go API. Defaults to the
# in-network address; the server refuses to start in production if it is empty.
API_URL=http://api:8080

# ── Coolify General Tab Domains ──────────────────────────────
# These are set in Coolify's general tab, NOT here. Listed for reference:
#   web-next: https://nationcam.com  ← holds the domain after the P1c cutover
#   web:      (no domain — legacy SPA, kept only for rollback)
#   api:      https://api.nationcam.com (optional, frontend uses the /api proxy)
#
# Logto is deployed as a separate service in Coolify.
# Coolify auto-generates SERVICE_URL_WEB etc.
